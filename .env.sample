# Claude Configuration
CLAUDE_API_KEY=your_claude_api_key_here
# Custom API endpoint for Claude (optional)
# Use this to point to staging environments, local proxies, or alternative endpoints
# Default production endpoint: https://api.anthropic.com
CLAUDE_API_ENDPOINT=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6

# Claude Bedrock Configuration (provider: claude-bedrock)
# Uses AWS default credential chain for authentication:
#   1. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
#   2. Shared credentials file (~/.aws/credentials)
#   3. SSO / AWS Identity Center (via ~/.aws/config)
#   4. IAM instance role (EC2, ECS, Lambda)
# No API key is needed — AWS credentials handle authentication.
CLAUDE_BEDROCK_REGION=us-east-1
# Use an inference profile ID (not a raw model ID). AWS requires inference profiles
# for on-demand invocation. System-defined profiles use a region prefix, e.g.:
#   us.anthropic.claude-sonnet-4-20250514-v1:0   (US regions)
#   eu.anthropic.claude-sonnet-4-20250514-v1:0   (EU regions)
CLAUDE_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
# Custom Bedrock runtime endpoint (optional, defaults to standard regional endpoint)
# CLAUDE_BEDROCK_ENDPOINT=https://bedrock-runtime.us-east-1.amazonaws.com

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
# Custom API endpoint for OpenAI (optional)
# Use this to point to staging environments, local proxies, or alternative endpoints
# Default production endpoint: https://api.openai.com
# The OpenAI SDK internally concatenates the default production endpoint with the
#   API version (like "/v1"). The remainder of the URL is the capability (like
#   "/chat/completions"). A good example of a custom endpoint is an Azure OpenAI
#   endpoint. Its structure is <tenant endpoint>/openai/<API version>. Then the
#   remainder of the URL is the capability, just like hitting api.openai.com
#   directly.
OPENAI_API_ENDPOINT=
OPENAI_MODEL=gpt-5.4-mini

# Azure OpenAI Configuration (provider: openai-azure)
OPENAI_AZURE_ENDPOINT=https://your-resource.openai.azure.com
OPENAI_AZURE_MODEL=gpt-4o-mini
OPENAI_AZURE_API_VERSION=2024-12-01-preview

# Requires Microsoft Entra ID (Azure AD) service principal credentials.
# These map to the standard AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET
# environment variables used by DefaultAzureCredential.
OPENAI_AZURE_SP_TENANT_ID=your_azure_tenant_id_here
OPENAI_AZURE_SP_CLIENT_ID=your_azure_client_id_here
OPENAI_AZURE_SP_CLIENT_SECRET=your_azure_client_secret_here

OPENAI_AZURE_UP_CLIENT_ID=your_azure_client_id_here
OPENAI_AZURE_UP_USERNAME=your_azure_username_here
OPENAI_AZURE_UP_PASSWORD=your_azure_password_here

# Logging Configuration
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Enable verbose output for troubleshooting
VERBOSE=true
