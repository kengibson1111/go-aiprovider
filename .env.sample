# Claude Configuration
CLAUDE_API_KEY=your_claude_api_key_here
# Custom API endpoint for Claude (optional)
# Use this to point to staging environments, local proxies, or alternative endpoints
# Default production endpoint: https://api.anthropic.com
CLAUDE_API_ENDPOINT=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
# Custom API endpoint for OpenAI (optional)
# Use this to point to staging environments, local proxies, or alternative endpoints
# Default production endpoint: https://api.openai.com
# The OpenAI SDK internally concatenates the default production endpoint with the
#   API version (like "/v1"). The remainder of the URL is the capability (like
#   "/chat/completions"). A good example of a custom endpoint is an Azure OpenAI
#   endpoint. Its structure is <tenant endpoint>/openai/<API version>. Then the
#   remainder of the URL is the capability, just like hitting api.openai.com
#   directly.
OPENAI_API_ENDPOINT=
OPENAI_MODEL=gpt-5.4-mini

# Azure OpenAI Configuration (provider: openai-azure)
# Requires Microsoft Entra ID (Azure AD) service principal credentials.
# These map to the standard AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET
# environment variables used by DefaultAzureCredential.
OPENAI_AZURE_ENDPOINT=https://your-resource.openai.azure.com
OPENAI_AZURE_MODEL=gpt-4o-mini
OPENAI_AZURE_TENANT_ID=your_azure_tenant_id_here
OPENAI_AZURE_CLIENT_ID=your_azure_client_id_here
OPENAI_AZURE_CLIENT_SECRET=your_azure_client_secret_here
OPENAI_AZURE_API_VERSION=2024-12-01-preview

# Logging Configuration
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Enable verbose output for troubleshooting
VERBOSE=true
